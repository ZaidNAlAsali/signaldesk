# Local defaults. Copy to .env and change values as needed.
POSTGRES_DB=signaldesk
POSTGRES_USER=signaldesk
POSTGRES_PASSWORD=signaldesk_dev_only

SIGNALDESK_ENVIRONMENT=development
SIGNALDESK_AI_PROVIDER=demo
SIGNALDESK_DATABASE_URL=sqlite:///./signaldesk.db
SIGNALDESK_AUTO_CREATE_SCHEMA=true
SIGNALDESK_SEED_DEMO_DATA=true
SIGNALDESK_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# External provider, optional. Never commit a real token.
SIGNALDESK_OPENAI_API_KEY=
SIGNALDESK_OPENAI_MODEL=gpt-5-mini
SIGNALDESK_OPENAI_BASE_URL=https://api.openai.com/v1
SIGNALDESK_OPENAI_API_MODE=responses
SIGNALDESK_PROVIDER_LABEL=openai
SIGNALDESK_PROVIDER_TIMEOUT_SECONDS=30
SIGNALDESK_PROVIDER_MAX_RETRIES=2

NEXT_PUBLIC_API_URL=http://localhost:8000
